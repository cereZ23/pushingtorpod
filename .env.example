# EASM Platform Environment Configuration
# Copy this file to .env and customize for your environment

# =============================================================================
# APPLICATION
# =============================================================================
APP_NAME="EASM Platform"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=production

# =============================================================================
# API SERVER
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=false

# =============================================================================
# SECURITY (CRITICAL: MUST CHANGE IN PRODUCTION)
# =============================================================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_THIS_IN_PRODUCTION_USE_LONG_RANDOM_STRING
JWT_SECRET_KEY=CHANGE_THIS_JWT_SECRET_IN_PRODUCTION_USE_LONG_RANDOM_STRING

# JWT Token Expiration
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

# API Key Header
API_KEY_HEADER=X-API-Key

# CORS Configuration
CORS_ORIGINS=["https://yourdomain.com"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["GET","POST","PUT","DELETE","PATCH"]
CORS_ALLOW_HEADERS=["*"]

# =============================================================================
# DATABASE
# =============================================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=easm
POSTGRES_USER=easm
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# Connection Pool Settings
POSTGRES_POOL_SIZE=20
POSTGRES_MAX_OVERFLOW=40
POSTGRES_POOL_PRE_PING=true
POSTGRES_POOL_RECYCLE=3600

# =============================================================================
# REDIS
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# =============================================================================
# CELERY
# =============================================================================
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TASK_ALWAYS_EAGER=false
CELERY_WORKER_PREFETCH_MULTIPLIER=4
CELERY_WORKER_MAX_TASKS_PER_CHILD=1000

# =============================================================================
# MINIO / S3 STORAGE
# =============================================================================
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=CHANGE_THIS_MINIO_ACCESS_KEY
MINIO_SECRET_KEY=CHANGE_THIS_MINIO_SECRET_KEY
MINIO_SECURE=false
MINIO_BUCKET_PREFIX=easm

# =============================================================================
# TOOL EXECUTION SECURITY
# =============================================================================
TOOL_EXECUTION_TIMEOUT=600
TOOL_EXECUTION_MAX_OUTPUT_SIZE=104857600  # 100MB in bytes
TOOL_TEMP_DIR=/tmp/easm-tools

# =============================================================================
# DISCOVERY PIPELINE TIMEOUTS (seconds)
# =============================================================================
DISCOVERY_BATCH_SIZE=100
DISCOVERY_SUBFINDER_TIMEOUT=600
DISCOVERY_DNSX_TIMEOUT=600
DISCOVERY_HTTPX_TIMEOUT=900
DISCOVERY_NAABU_TIMEOUT=1200
DISCOVERY_NUCLEI_TIMEOUT=1800

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_REQUESTS_PER_HOUR=1000

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json  # json or text
LOG_FILE=/var/log/easm/app.log
LOG_ROTATION_SIZE=100MB
LOG_RETENTION_DAYS=30

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================
# Sentry Error Tracking (optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# =============================================================================
# FEATURE FLAGS
# =============================================================================
FEATURE_UNCOVER_ENABLED=true
FEATURE_NUCLEI_ENABLED=true
FEATURE_NOTIFICATIONS_ENABLED=false

# =============================================================================
# OSINT API KEYS (Encrypted per-tenant, these are defaults)
# =============================================================================
# These should be encrypted and stored per-tenant in the database
# SHODAN_API_KEY=
# CENSYS_API_ID=
# CENSYS_API_SECRET=
# VIRUSTOTAL_API_KEY=
# SECURITYTRAILS_API_KEY=
